---
layout: default
---

<article class="memory-verse-card" data-week="<%= data.week %>">

  <header class="mv-header">
    <span class="mv-phase"><%= data.phase %></span>
    <h1>Week <%= data.week %>: Memory Verse</h1>
    <p class="mv-week-title"><%= data.title %></p>
  </header>

  <section class="mv-verse-row">
    <% if data.image %>
      <figure class="mv-image">
        <img src="<%= relative_url "/images/memory-verses/#{data.image}" %>" alt="Memory verse illustration for Week <%= data.week %>">
      </figure>
    <% end %>
    <div class="mv-verse">
      <blockquote class="mv-text">
        <%= data.verse_text %>
      </blockquote>
      <cite class="mv-reference"><%= data.memory_verse %></cite>
      <span class="mv-translation">(<%= data.translation %>)</span>
      <button class="mv-listen-btn"
              data-reference="<%= data.memory_verse %>"
              data-verse="<%= data.verse_text %>"
              aria-label="Listen to memory verse">
        <svg class="mv-listen-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
        </svg>
        <span class="mv-listen-label">Listen</span>
      </button>
    </div>
  </section>

  <section class="mv-context">
    <h2>Why This Verse</h2>
    <%= yield %>
  </section>

  <section class="mv-connections">
    <h2>Connections This Week</h2>
    <ul>
      <% data.connections&.each do |conn| %>
        <li><%= conn %></li>
      <% end %>
    </ul>
  </section>

  <footer class="mv-footer">
    <div class="mv-footer-actions">
      <!-- Mark Complete button inserted here by JS -->
    </div>

    <a href="<%= relative_url '/memory-verses#all-verses' %>" class="mv-progress-link" target="_blank" rel="noopener">
      Check Your Progress — All 52 Verses
    </a>

    <%
      week = data.week.to_i
      week_phases = site.data.week_phases.transform_keys(&:to_i)
      current_phase_dir = week_phases[week]

      # Find all weeks in the current phase
      phase_weeks = week_phases.select { |_w, dir| dir == current_phase_dir }.keys.sort

      # Find previous and next phase names for the arrows
      first_week = phase_weeks.first
      last_week = phase_weeks.last
      prev_phase_dir = first_week > 1 ? week_phases[first_week - 1] : nil
      next_phase_dir = last_week < 52 ? week_phases[last_week + 1] : nil

      # Phase display names
      phase_names = {
        "phase-1-the-coming-of-christ" => "Phase 1",
        "phase-2-galilean-ministry" => "Phase 2",
        "phase-3-road-to-jerusalem" => "Phase 3",
        "phase-4-passion-and-resurrection" => "Phase 4",
        "phase-5-the-early-church" => "Phase 5",
        "phase-6-letters-and-revelation" => "Phase 6",
      }

      # Previous phase links to its last week's memory verse
      prev_phase_last_week = prev_phase_dir ? week_phases.select { |_w, dir| dir == prev_phase_dir }.keys.max : nil
      next_phase_first_week = next_phase_dir ? week_phases.select { |_w, dir| dir == next_phase_dir }.keys.min : nil
    %>
    <nav class="week-nav">
      <% if prev_phase_dir %>
        <a href="<%= relative_url "/#{prev_phase_dir}/week-#{'%02d' % prev_phase_last_week}/memory-verse/" %>" class="week-nav-arrow">&larr; <%= phase_names[prev_phase_dir] %></a>
      <% else %>
        <span class="week-nav-arrow"></span>
      <% end %>
      <div class="week-nav-pages">
        <% phase_weeks.each do |w| %>
          <% is_current = w == week %>
          <a href="<%= relative_url "/#{current_phase_dir}/week-#{'%02d' % w}/memory-verse/" %>" class="week-nav-page<%= ' current' if is_current %>"><%= w %></a>
        <% end %>
      </div>
      <% if next_phase_dir %>
        <a href="<%= relative_url "/#{next_phase_dir}/week-#{'%02d' % next_phase_first_week}/memory-verse/" %>" class="week-nav-arrow"><%= phase_names[next_phase_dir] %> &rarr;</a>
      <% else %>
        <span class="week-nav-arrow"></span>
      <% end %>
    </nav>
  </footer>

  <section class="page-discussions" data-feature="discussions">
    <h2>Discussion</h2>
    <p class="discussions-note">Comments are powered by GitHub Discussions. To post, sign in with your GitHub account using the link below the reaction icons.</p>
    <div class="giscus"></div>
  </section>

</article>
