---
layout: default
---

<div data-page="home"></div>
<section class="hero" style="background: linear-gradient(135deg, rgba(30,18,53,0.85), rgba(39,24,69,0.8)), url('<%= relative_url '/images/open_bible.png' %>') center bottom / contain no-repeat, linear-gradient(135deg, var(--purple-deep), var(--purple-mid));">
  <h1 class="hero-title">The New Testament<br><span>A Year at His Feet</span></h1>
  <p class="hero-tagline">A 52-week chronological journey through all 260 chapters</p>
  <p class="hero-verse">"All Scripture is God-breathed and is useful for teaching, rebuking, correcting and training in righteousness."<br><span class="verse-ref">— 2 Timothy 3:16</span></p>
</section>

<div id="todays-study"></div>

<section class="phases">
  <h2>The Six Phases</h2>

  <div class="phase-grid">
    <a href="<%= relative_url '/phase-1-the-coming-of-christ/' %>" class="phase-card phase-1">
      <span class="phase-number">Phase 1</span>
      <span class="phase-name">The Coming of Christ</span>
      <span class="phase-weeks">Weeks 1–4</span>
    </a>
    <a href="<%= relative_url '/phase-2-galilean-ministry/' %>" class="phase-card phase-2">
      <span class="phase-number">Phase 2</span>
      <span class="phase-name">Galilean Ministry</span>
      <span class="phase-weeks">Weeks 5–11</span>
    </a>
    <a href="<%= relative_url '/phase-3-road-to-jerusalem/' %>" class="phase-card phase-3">
      <span class="phase-number">Phase 3</span>
      <span class="phase-name">Road to Jerusalem</span>
      <span class="phase-weeks">Weeks 12–16</span>
    </a>
    <a href="<%= relative_url '/phase-4-passion-and-resurrection/' %>" class="phase-card phase-4">
      <span class="phase-number">Phase 4</span>
      <span class="phase-name">Passion & Resurrection</span>
      <span class="phase-weeks">Weeks 17–20</span>
    </a>
    <a href="<%= relative_url '/phase-5-the-early-church/' %>" class="phase-card phase-5">
      <span class="phase-number">Phase 5</span>
      <span class="phase-name">The Early Church</span>
      <span class="phase-weeks">Weeks 21–41</span>
    </a>
    <a href="<%= relative_url '/phase-6-letters-and-revelation/' %>" class="phase-card phase-6">
      <span class="phase-number">Phase 6</span>
      <span class="phase-name">Letters & Revelation</span>
      <span class="phase-weeks">Weeks 42–52</span>
    </a>
  </div>
</section>

<%= yield %>

<section class="guides">
  <h2>Before You Begin</h2>
  <div class="guide-cards">
    <a href="<%= relative_url '/how-to-use' %>" class="guide-card">
      <h3>How to Use This Study</h3>
      <p>Daily routine, weekly rhythm, group and individual study tips.</p>
    </a>
    <a href="<%= relative_url '/chronological-overview' %>" class="guide-card">
      <h3>Why Chronological?</h3>
      <p>How reading in historical order transforms your understanding.</p>
    </a>
    <a href="<%= relative_url '/hear-method' %>" class="guide-card">
      <h3>The H.E.A.R. Method</h3>
      <p>A four-step journaling approach: Highlight, Explain, Apply, Respond.</p>
    </a>
  </div>
</section>
